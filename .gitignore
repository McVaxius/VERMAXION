## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio cache
.vs/

# Rider
.idea/

# NuGet
packages/
*.nupkg

# Backup folder
backups/

# Non-end-user docs (learning/dev docs live in xa-xiv-docs)
*.md
!README.md
!CHANGELOG.md

# Lock files
packages.lock.json
